rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function ownsUserDocument(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read, create, update, delete: if ownsUserDocument(userId);

      match /providerTokens/{connectionId} {
        allow read, create, update, delete: if false;
      }

      match /{collectionId}/{documentId} {
        allow read, create, update, delete: if collectionId != "providerTokens" && ownsUserDocument(userId);
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
